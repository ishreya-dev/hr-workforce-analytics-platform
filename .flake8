[flake8]
max-line-length = 100
extend-ignore = E203, W503
exclude = 
    .git,
    __pycache__,
    .venv,
    venv,
    env,
    build,
    dist,
    .eggs,
    *.egg,
    .tox,
    .mypy_cache,
    .pytest_cache,
    htmlcov
per-file-ignores =
    __init__.py:F401
    tests/*:E501,F811
    conftest.py:E501
max-complexity = 10
statistics = True
count = True