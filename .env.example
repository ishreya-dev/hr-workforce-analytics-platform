# HR Attrition & Workforce Analytics - Environment Configuration
# Copy this file to .env and update the values for your environment
# DO NOT commit .env to version control (it's in .gitignore)

# ---------------------------------------------------------------------------
# Environment
# ---------------------------------------------------------------------------
# Environment mode: development, staging, production
ENV=development

# Logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# ---------------------------------------------------------------------------
# Paths (optional overrides - defaults are relative to repo root)
# ---------------------------------------------------------------------------
# Path to the raw Excel workbook
# RAW_WORKBOOK_PATH=Analytics/Excel/HR DATA_Excel.xlsx

# Path for processed CSV output
# PROCESSED_DATA_PATH=Data/processed/hrdata_clean.csv

# Path for SQLite database (local development)
# DB_PATH=ETL/SQL/hr_analytics.db

# Directory for log files
# LOG_DIR=ETL/Python/logs

# ---------------------------------------------------------------------------
# Database Configuration (for production PostgreSQL deployment)
# ---------------------------------------------------------------------------
# Database type: sqlite, postgresql
# DB_TYPE=sqlite

# PostgreSQL settings (only used if DB_TYPE=postgresql)
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=hr_analytics
# DB_USER=analytics_user
# DB_PASSWORD=changeme_in_production

# Connection pool settings (for PostgreSQL)
# DB_POOL_SIZE=5
# DB_MAX_OVERFLOW=10

# ---------------------------------------------------------------------------
# Data Validation Settings
# ---------------------------------------------------------------------------
# Age range for validation
# AGE_MIN=16
# AGE_MAX=75

# Job level range
# JOB_LEVEL_MIN=1
# JOB_LEVEL_MAX=5

# Stock option level range
# STOCK_OPTION_MIN=0
# STOCK_OPTION_MAX=3

# Performance rating range
# PERFORMANCE_RATING_MIN=1
# PERFORMANCE_RATING_MAX=4

# Satisfaction scale range (1-4)
# SCALE_1_4_MIN=1
# SCALE_1_4_MAX=4

# ---------------------------------------------------------------------------
# Pipeline Settings
# ---------------------------------------------------------------------------
# Enable/disable specific validation checks
# VALIDATE_UNIQUENESS=true
# VALIDATE_DOMAINS=true
# VALIDATE_RANGES=true
# PROFILE_CONDITIONAL_DROPS=true

# Retry settings for transient failures
# MAX_RETRIES=3
# RETRY_DELAY_SECONDS=2

# ---------------------------------------------------------------------------
# Feature Flags (for gradual rollout of new features)
# ---------------------------------------------------------------------------
# Enable new compensation analysis (v2.0 feature)
# ENABLE_COMPENSATION_ANALYSIS=true

# Enable new tenure analysis (v2.0 feature)
# ENABLE_TENURE_ANALYSIS=true

# Enable structured JSON logging
# ENABLE_STRUCTURED_LOGGING=false

# ---------------------------------------------------------------------------
# Monitoring & Observability (for production)
# ---------------------------------------------------------------------------
# Enable metrics collection
# ENABLE_METRICS=false

# Metrics endpoint (Prometheus, StatsD, etc.)
# METRICS_ENDPOINT=

# Enable distributed tracing
# ENABLE_TRACING=false

# Tracing endpoint (Jaeger, Zipkin, etc.)
# TRACING_ENDPOINT=

# ---------------------------------------------------------------------------
# Security Settings
# ---------------------------------------------------------------------------
# Enable data masking in logs (for production)
# ENABLE_DATA_MASKING=false

# Allowed file extensions for upload
# ALLOWED_EXTENSIONS=.xlsx,.xls,.csv

# Maximum file size (MB)
# MAX_FILE_SIZE_MB=50

# ---------------------------------------------------------------------------
# Performance Tuning
# ---------------------------------------------------------------------------
# Batch size for processing large files
# BATCH_SIZE=1000

# Number of worker processes (for parallel processing)
# NUM_WORKERS=1

# Enable caching
# ENABLE_CACHE=false

# Cache TTL in seconds
# CACHE_TTL=3600

# ---------------------------------------------------------------------------
# Notification Settings (for production monitoring)
# ---------------------------------------------------------------------------
# Send alerts on pipeline failure
# ALERT_ON_FAILURE=false

# Alert email recipients
# ALERT_EMAIL_RECIPIENTS=

# Slack webhook for notifications
# SLACK_WEBHOOK_URL=

# ---------------------------------------------------------------------------
# Development Settings
# ---------------------------------------------------------------------------
# Enable debug mode (verbose logging, no retries)
# DEBUG=false

# Skip data validation (for testing only - NEVER use in production)
# SKIP_VALIDATION=false

# Use mock data instead of real files
# USE_MOCK_DATA=false

# ---------------------------------------------------------------------------
# Notes
# ---------------------------------------------------------------------------
# 1. Copy this file to .env: cp .env.example .env
# 2. Update values as needed for your environment
# 3. Never commit .env to version control
# 4. For production, set environment variables directly in your deployment platform
# 5. All paths can be absolute or relative to the repository root